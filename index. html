<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nourk App</title>
    
    <script src="https://sdk.minepi.com/pi-sdk.js"></script>
    <script>
        // تفعيل الربط مع الشبكة (التيستنت)
        Pi.init({ version: "2.0", sandbox: true });
    </script>

    <style>
        body { font-family: Arial, sans-serif; text-align: center; background-color: #f4f4f9; padding: 50px; }
        .container { background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        button { background-color: #673ab7; color: white; border: none; padding: 15px 30px; border-radius: 10px; cursor: pointer; font-size: 18px; }
        button:hover { background-color: #512da8; }
        h1 { color: #673ab7; }
    </style>
</head>
<body>

    <div class="container">
        <h1>مرحباً بك في تطبيق Nourk 💡</h1>
        <p>اضغط تحت عشان تجرب عملية دفع وهمية بفلوس التيستنت</p>
        
        <button onclick="transferPi()">تجربة دفع (Test Pi)</button>
    </div>

    <script>
        async function transferPi() {
            try {
                const payment = await Pi.createPayment({
                    amount: 0.1, // مبلغ التجربة
                    memo: "تجربة دفع في تطبيق نورك", // وصف العملية
                    metadata: { orderId: 123 }
                }, {
                    onReadyForServerApproval: (paymentId) => {
                        console.log("العملية جاهزة للموافقة: ", paymentId);
                        // هنا الخطوة اللي بتحتاج سيرفر بس حالياً بنجرب الواجهة
                    },
                    onReadyForServerCompletion: (paymentId, txid) => {
                        console.log("العملية تمت بنجاح! رقم المعاملة: ", txid);
                    },
                    onCancel: (paymentId) => { console.log("تم إلغاء العملية"); },
                    onError: (error, payment) => { console.error("خطأ في الدفع: ", error); }
                });
            } catch (err) {
                alert("لازم تفتح التطبيق من جوه Pi Browser عشان الدفع يشتغل!");
            }
        }
    </script>

</body>
</html>
